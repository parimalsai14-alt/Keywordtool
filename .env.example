# Copy to .env and fill in. Do not commit .env.
NODE_ENV=production
PORT=3000

# Required in production: long random string (e.g. run: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-long-random-string

# Optional: override login passwords (defaults are in server.js)
# ADMIN_PASSWORD=your_admin_password
# EMPLOYEE_PASSWORD=your_employee_password

# Optional: default Serper API key (admin can change from Settings in the app)
# SERPER_API_KEY=your_serper_api_key
